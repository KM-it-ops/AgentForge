{
  "name": "@kmitops/agentforge",
  "version": "0.3.1",
  "description": "A configuration framework for agentic AI coding assistants. One spec. Many adapters. The same posture in any agent.",
  "keywords": [
    "agent",
    "claude",
    "claude-code",
    "codex",
    "gemini-cli",
    "cursor",
    "aider",
    "ai-coding",
    "llm",
    "config",
    "skills"
  ],
  "license": "MIT",
  "author": "Mahmoud Kurdi",
  "repository": {
    "type": "git",
    "url": "https://github.com/KM-it-ops/AgentForge.git"
  },
  "homepage": "https://github.com/KM-it-ops/AgentForge#readme",
  "bugs": {
    "url": "https://github.com/KM-it-ops/AgentForge/issues"
  },
  "bin": {
    "agentforge": "bin/agentforge.js"
  },
  "main": "bin/agentforge.js",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "CHANGELOG.md",
    "docs/*.md",
    "!docs/GOALBUDDY-HANDOFF.md",
    "docs/demo/",
    "docs/releases/",
    "spec/",
    "scripts/",
    "universal/",
    "adapters/",
    "bootstrap/",
    "README.md"
  ],
  "scripts": {
    "demo": "node scripts/serve-demo.js",
    "test": "node scripts/run-bash-script.js scripts/round-trip-test.sh",
    "test:merge-safe": "node scripts/run-bash-script.js scripts/merge-safe-test.sh",
    "test:pack": "node scripts/run-bash-script.js scripts/pack-install-test.sh",
    "test:mcp": "node scripts/run-bash-script.js scripts/mcp-emit-test.sh",
    "test:spec-public": "node scripts/run-bash-script.js scripts/check-spec-public.sh",
    "verify": "npm run test:spec-public && npm test && npm run test:merge-safe && npm run test:pack && npm run test:mcp"
  }
}
